# QVeris is required for live news capture and historical backfill.
# Register: https://qveris.ai
QVERIS_API_KEY=qv_your_key_here

# DeepSeek is used through the OpenAI-compatible chat API for Chinese
# translation and narrative/direction analysis.
# Register: https://platform.deepseek.com
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
OPENAI_API_KEY=sk_your_deepseek_key_here

# Optional: enrich article text when building historical datasets.
# Register: https://www.firecrawl.dev
# FIRECRAWL_API_KEY=fc_your_key_here
